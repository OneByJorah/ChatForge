# ─────────────────────────────────────────────────────────────
# ChatForge — Cloudflare Workers Environment Variables
# Copy to .env before deploying
# ─────────────────────────────────────────────────────────────

# Cloudflare API credentials (required for deployment)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Optional: Custom worker name (defaults to "chatforge" from wrangler.jsonc)
# WORKER_NAME=chatforge
